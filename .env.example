# Ryanair API mode:
#   fixtures      = read from src/lib/__fixtures__ (default; offline-safe)
#   live          = always hit services-api.ryanair.com
#   live-fallback = try live, fall back to fixtures on error
RYANAIR_MODE=fixtures

# Weather API mode (defaults to follow RYANAIR_MODE if unset):
#   fixtures = synthetic deterministic weather, no network
#   live     = hit api.open-meteo.com / climate-api.open-meteo.com
WEATHER_MODE=fixtures
